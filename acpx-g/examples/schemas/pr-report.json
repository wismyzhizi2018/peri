{
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Report title"
    },
    "sections": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of report section headings"
    },
    "verdict": {
      "type": "string",
      "enum": ["approve", "request_changes", "needs_discussion"],
      "description": "Final review verdict"
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10,
      "description": "Code quality score"
    }
  },
  "required": ["title", "sections", "verdict", "score"]
}
